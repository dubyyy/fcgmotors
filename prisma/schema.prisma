generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Car {
  id          Int      @id @default(autoincrement())
  brand       String
  model       String
  year        Int
  price       String
  category    String   @default("Luxury")
  imageUrls   String[] @default([])
  description String
  createdAt   DateTime @default(now())
}

model SparePart {
  id          Int      @id @default(autoincrement())
  name        String
  partNumber  String?
  category    String
  price       String
  imageUrls   String[] @default([])
  description String
  createdAt   DateTime @default(now())
}
